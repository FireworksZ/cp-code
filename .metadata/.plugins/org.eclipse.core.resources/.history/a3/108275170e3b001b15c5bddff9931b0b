long long mod = 1000000007LL;
const long long large = 2000000000000000000LL;

typedef unsigned long long ull;

typedef pair<long long,ii> lii;

vector<int> maxi;
int up,uv;
void update(int o,int l,int r){
	if(l==r){
		maxi[o] = uv;
	}else{
		int m = (l+r)/2;
		if(up<=m) update(o*2,l,m);
		if(up>m) update(o*2+1,m+1,r);
		maxi[o] = max(maxi[o*2],maxi[o*2+1]);
	}
}

int ql,qr,qv;
void query(int o,int l,int r){
	if(ql<=l&&qr>=r){
		qv = max(qv,maxi[o]);
	}else{
		int m = (l+r)/2;
		if(ql<=m) query(o*2,l,m);
		if(qr>m) query(o*2+1,m+1,r);
	}
}

int main(){

	ios::sync_with_stdio(false);

//    freopen("input.txt","r",stdin);
//    freopen("output.txt","w",stdout);

	int n,m;
	cin>>n>>m;
	vector<long long> a(n,0);
	for(int i=0;i<n;i++) cin>>a[i];
	vector<lii> e;
	for(int i=0;i<n;i++){
		long long sum = 0;
		for(int j=i;j<n;j++){
			sum+=a[j];
			e.push_back(lii(sum,ii(i,j)));
		}
	}
	sort(e.begin(),e.end());

	map<ii,int> comp;
	for(int i=0;i<(int)e.size();i++) comp[e[i].second] = i;

	vector<vector<lii> > adj(n,vector<lii>());
	vector<long long> re(m,-large);
	for(int i=0;i<m;i++){
		int s,e;
		long long u;
		cin>>s>>e>>u;
		s--;e--;
		adj[e].push_back(lii(u,ii(s,i)));
	}
	int sz = (int)e.size();
	maxi.assign(4*sz+10,-large);
	for(int i=0;i<n;i++){
		for(int j=0;j<=i;j++){
			int t = comp[ii(j,i)];
			up = t;
			uv = j;
			update(1,0,sz-1);
		}
		for(int j=0;j<(int)adj[i].size();j++){
			long long u = adj[i][j].first;
			long long s = adj[i][j].second.first;
			int p = upper_bound(e.begin(),e.end(),lii(u,ii(1000000000,-1)))-e.begin();
			p--;
			int low = 0;
			int high = p;
			int ans = -1;
			while(low<=high){
				int mid = (low+high)/2;
				ql = mid;
				qr = p;
				qv = -1;
				query(1,0,sz-1);
				if(qv>=s){
					ans = mid;
					low = mid+1;
				}else{
					high = mid-1;
				}
			}
			int t = adj[i][j].second.second;
			if(ans!=-1){
				re[t] = e[ans].first;
			}
		}
	}
	for(int i=0;i<m;i++){
		if(re[i]==-large) cout<<"NONE"<<endl;
		else cout<<re[i]<<endl;
	}

    return 0;
}
