bool partition(vector<int> a,vector<int>& b){
	int c = 0;
	int n = (int)a.size();
	for(int i=0;i<n;i++) c+=a[i];
	if(c%2) return false;
	int h = c/2;
	vector<vector<int> > dp(n+1,vector<int>(h+1,0));

	dp[0][0] = 1;
	for(int i=1;i<=n;i++){
		int v = a[i-1];
		for(int j=0;j<=h;j++){
			if(dp[i-1][j] == 1){
				dp[i][j] = 1 ;
			}
			if(j>=v) dp[i][j]|=dp[i-1][j-v];
		}
	}

}


