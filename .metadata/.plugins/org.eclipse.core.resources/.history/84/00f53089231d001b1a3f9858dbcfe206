		for(int i=0;i<n;i++){
			int x;
			cin>>x;
			if(a.empty()||a.back()!=x) a.push_back(x);
		}
		n = (int)a.size();
		int l = 1;
		while(l<n&&a[l]<a[l-1]) l++;
		int r = n-2;
		while(r>=0&&a[r]<a[r+1]) r--;
		if(l>r){
			cout<<"YES"<<endl;
			continue;
		}
		if(a[l-1]+a[r+1]>=a[l])cout<<"YES"<<endl;
		else cout<<"NO"<<endl;

	}


    return 0;
}
